  <script>
    function selectScale(element, category, index) {
      // update UI
      const parent = element.parentNode;
      parent.querySelectorAll('.scale-node-wrapper').forEach(el => el.classList.remove('active'));
      element.classList.add('active');

      // sync the hidden range input
      const overlay = element.closest('.scale-track-container').querySelector('.scale-range-overlay');
      if (overlay) overlay.value = index;

      // save to state
      userProgressData[`scale-${category}`] = index;
      localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
    }

    function syncScaleOverlay(inputElement, category) {
      const val = parseInt(inputElement.value, 10);
      const parent = inputElement.parentNode;
      const nodes = parent.querySelectorAll('.scale-node-wrapper');
      if (nodes[val]) {
        nodes.forEach(el => el.classList.remove('active'));
        nodes[val].classList.add('active');

        userProgressData[`scale-${category}`] = val;
        localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
      }
    }

    // 建立塵埃粒子
    function createDustMotes() {
      const container = document.getElementById('dust-motes');
      if (!container) return;
      const moteCount = 15;
      for (let i = 0; i < moteCount; i++) {
        const mote = document.createElement('div');
        mote.classList.add('mote');

        const size = Math.random() * 4 + 2;
        const left = Math.random() * 100;
        const duration = Math.random() * 15 + 10;
        const delay = Math.random() * -20;

        mote.style.width = `${size}px`;
        mote.style.height = `${size}px`;
        mote.style.left = `${left}vw`;
        mote.style.animationDuration = `${duration}s`;
        mote.style.animationDelay = `${delay}s`;

        container.appendChild(mote);
      }
    }

    function setupValidation() {
      // 針對有輸入框的頁面進行驗證
      document.querySelectorAll('.page-container').forEach(page => {
        const inputs = page.querySelectorAll('.text-input');
        // 找到該頁面的主要動作按鈕
        const actionBtns = page.querySelectorAll('.action-btn');

        if (inputs.length > 0 && actionBtns.length > 0) {
          // 初始化時禁用按鈕
          actionBtns.forEach(btn => btn.disabled = true);

          const checkInputs = () => {
            let allValid = true;
            // 該頁面的所有輸入框都必須大於等於兩個字
            inputs.forEach(input => {
              if (input.value.trim().length < 2) {
                allValid = false;
              }
            });
            // 根據驗證結果啟用或禁用按鈕
            actionBtns.forEach(btn => btn.disabled = !allValid);
          };

          // 綁定輸入事件
          inputs.forEach(input => {
            input.addEventListener('input', checkInputs);
          });
        }
      });
    }

    let userProgressData = {};
    let lastSummaryPage = 'page-event-summary-want';
    let careerRPG_page = 'page-want-or-not';

    async function analyzeByCloud(text) {
      if (!text || text === '無輸入內容') return [];

      // 判定是否為地端：localhost, 127.0.0.1 或直接開啟檔案 (hostname 為空)
      const isLocal = window.location.hostname === 'localhost' ||
        window.location.hostname === '127.0.0.1' ||
        window.location.hostname === '';

      try {
        if (isLocal) {
          // 【地端模式】呼叫本地 Ollama
          const response = await fetch('http://localhost:11434/api/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: 'career-analyzer',
              prompt: `你是一個專業的職涯標籤辨識系統。
你的任務是：根據使用者輸入的經歷描述，從以下【標籤庫】中，選出最符合的 2 至 3 個標籤。

【規則】
1. 只能從標籤庫中選取，不得自行創建新標籤。
2. 每個標籤必須有描述中的明確證據支撐，不得推斷未提及內容。
3. 若描述不足以支撐任何標籤，請回傳空陣列：{"tags": []}。
4. 輸出格式必須嚴格遵守 JSON 結構，如：{"tags": ["A01: 專業內容的跨背景轉譯", "B03: 高頻目標調整之持續應對需求"]}。
5. 不要輸出 any 解釋文字，只要回傳 JSON。

【判定校正規則】（強制遵循）
1. 自學與技術研發排除：禁止將任何「自學技術、自學 Web 框架、寫程式、研發核心架構」等操作判定為 D03: 訪談與提問引導。這些應歸為 D09: 通用數位工具操作。若涉及學習沉沒成本則可判定為 C14: 領域專有技術的高沉沒成本。
2. 心靈情緒支持排除：禁止將「心靈支持」、「安撫家屬情緒」、「安撫焦慮」等精神消耗判定為 B10: 持續性體能動員的工作型態 或 D12: 大肌肉動作執行。此類精神承接應判為 B01: 高強度情緒勞動涉入，若有口頭安慰則搭配 D01: 口語表達。
3. 資源與目標協調判定：禁止將「招募志工、分配清潔區域」判定為 B02: 高密度階層對接之認知負荷 或 D03: 訪談與提問引導。此為目標協調，應判為 A10: 多方可接受交集的判斷。
4. 數據/資訊整理與規律辨識區隔：禁止將單純用 Excel 或工具整理資料的動作判為 A03: 大量資訊中的規律辨識 或 A04: 分析框架的建立與定義。A03 必須有明確「看出底層重複規律或痛點結論」；A04 必須有「建立可重複操作結構」的分析架構。
5. 客訴環境判定：尖峰時刻客訴不斷、場面吵雜，應判為 B01: 高強度情緒勞動涉入 與 B06: 高密度感官刺激的工作環境，非 B02 或 A10。

【標籤庫】
A01: 專業內容的跨背景轉譯, A02: 模糊情境下的問題核心辨識, A03: 大量資訊中的規律辨識, A04: 分析框架的建立與定義, A05: 概念本質的釐清與定位, A06: 概念到執行方向的結構拆解, A07: 長程目標的規劃與查核設計, A08: 工作流程的診斷與改善判斷, A09: 多方立場與底線的解讀, A10: 多方可接受交集的判斷, A11: 複合變數失控下的應變判斷, A12: 實體空間使用邏輯的規劃判斷, A13: 資源條件與投入時機的判斷, A14: 特定對象行為模式的預測判斷, A15: 規則與情境的適用條件判斷, B01: 高強度情緒勞動涉入, B02: High密度階層對接之認知負荷, B03: 高頻目標調整之持續應對需求, B04: 高精準度要求與決策責任承擔, B05: 多方利益平衡之持續角色要求, B06: 高密度感官刺激的工作環境, B07: 低外部刺激與高重複性的工作型態, B08: 低外部節律依賴的獨立作業型態, B09: 工作與生活時間的高度交疊性, B10: 持續性體能動員的工作型態, B11: 高強度他人困境的持續涉入, B12: 持續性公眾可見度與表現要求, B13: 多工並行與高資訊密度的工作型態, B14: 低結構化指令與自主定義標準的工作型態, B15: 非常規作息與生理節律的持續調適需求, B16: 特定物理環境條件的持續工作型態, C01: 法定執業資格門檻, C02: 學歷背景的結構性篩選, C03: 強制過渡期的財務壓縮結構, C04: 非公開管道的機會依賴結構, C05: 作品集與可見成果的入場前提, C06: 財務回報的結構性延遲, C07: 收入波動與現金流不確定性, C08: 入行初期的財務資本墊付, C09: 薪資結構的制度性天花板, C10: 非常規排班的強制接受, C11: 高頻率地理移動的工作型態, C12: 執業場域的地理綁定限制, C13: 職涯機會的地理集中性, C14: 領域專有技術的高沉沒成本, C15: 技術迭代造成的持續再投入需求, C16: 職涯出口的結構性窄化, D01: 口語表達, D02: 主動傾聽與語義提取, D03: 訪談與提問引導, D04: 肢體示範與動作引導, D05: 結構化書面輸出, D06: 視覺化資訊呈現, D07: 質性資訊蒐集與整理, D08: 數據讀取與分析操作, D09: 通用數位工具操作, D10: 數位溝通工具操作, D11: 實體空間操作與設備使用, D12: 大肌肉動作執行, D13: 小肌肉精細操作

【訓練範例 (Few-Shot)】
經歷描述：我負責核心架構開發，在 48 小時內自學了全新的 Web 框架，並成功克服了多端同步的技術瓶頸，獲得導師高度肯定。
輸出：{"tags": ["B04: 高精準度要求與決策責任承擔", "C14: 領域專有技術的高沉沒成本"]}

經歷描述：在醫院擔任志工時，面對焦慮的家屬，我能冷靜地安撫他們的情緒並提供協助。即便這個過程非常耗費心神，但看到家屬能稍微安心，我願意再次投入這樣高強度的心靈支持工作。
輸出：{"tags": ["B01: 高強度情緒勞動涉入", "D01: 口語表達"]}

經歷描述：我曾獨立完成一個自動化報表系統，大幅減少了同仁手動輸入的時間。雖然主管當下沒有特別表揚，但我對自己能精簡流程並提升整體工作效率的成果感到非常滿意。
輸出：{"tags": ["A08: 工作流程的診斷與改善判斷", "D09: 通用數位工具操作"]}

經歷描述：在資源有限的情況下，我利用手邊現有的免代碼工具製作了一個自動化行銷漏斗。即使這不是我的本職工作，也沒有獎金，但看到實際轉換率因此提升，我覺得這種創造價值的過程非常迷人。
輸出：{"tags": ["D09: 通用數位工具操作", "A13: 資源條件與投入時機的判斷"]}

經歷描述：負責將公司超過十年、極其混亂的零散紙本檔案全部轉化為高效的數位檢索系統。
輸出：{"tags": ["A08: 工作流程的診斷與改善判斷", "D08: 數據讀取與分析操作"]}

經歷描述：我獨立規劃了資料庫架構與分類邏輯，克服了原始資料格式不一的問題，建立了一套讓團隊成員能在三秒內精準檢索的系統。
輸出：{"tags": ["A03: 大量資訊中的規律辨識", "D09: 通用數位工具操作"]}

經歷描述：在一次大型戶外活動中，原定的場地突然因為天氣因素無法使用，我迅速聯繫了備案場地並在兩小時內指揮搬運隊完成所有物資轉移。雖然過程混亂，但我對自己能靈活調度資源感到滿意。
輸出：{"tags": ["A11: 複合變數失控下的應變判斷", "A13: 資源條件與投入時機的判斷"]}

經歷描述：曾擔任繁忙捷運站旁的連鎖餐廳店長，在尖峰時刻面對人手嚴重不足且客訴不斷的壓力測試。
輸出：{"tags": ["B01: 高強度情緒勞動涉入", "B06: 高密度感官刺激的工作環境"]}

經歷描述：我曾主動發起一個鄰里清潔日活動，負責招募志願者並分配繁雜的清潔區域。看到鄰里環境變好，即便沒有任何物質報酬，我也覺得這種對社區的具體貢獻讓我非常有成就感。
輸出：{"tags": ["A10: 多方可接受交集的判斷", "D11: 實體空間操作與設備使用"]}

經歷描述：在上次駭客松比賽中，需要在極短時間內交付一個具備雲端同步功能的產品原型。
輸出：{"tags": ["A02: 模糊情境下的問題核心辨識", "D09: 通用數位工具操作"]}

經歷描述：\${text}
輸出：\`,
              stream: false,
              format: 'json'
            })
          });
          const data = await response.json();
          let rawText = data.response || '';
          // 移除 DeepSeek 的 <think> 標籤及其內容防止 JSON 解析失敗
          rawText = rawText.replace(/<think>[\s\S]*?<\/think>/g, '').trim();
          const result = JSON.parse(rawText);
          return result.tags || [];
        } else {
          // 【雲端模式】呼叫 Cloudflare Pages Functions (Groq)
          const response = await fetch('/analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: text })
          });
          const data = await response.json();
          if (!response.ok) return [data.error || '連線失敗'];
          return data.tags || [];
        }
      } catch (e) {
        console.error("分析失敗:", e);
        let errorMsg = '無法解析: ' + e.message;
        if (isLocal && e.message.includes('fetch')) {
          errorMsg = '無法解析: 請確保 Ollama 已啟動，並已執行「launchctl setenv OLLAMA_ORIGINS "*"」後重啟 Ollama';
        }
        return [errorMsg];
      }
    }

    function goTo(pageId, immediate = false) {
      const currentPage = document.querySelector('.page-container.active');
      const doSwitch = () => {
        const inputs = currentPage ? currentPage.querySelectorAll('.text-input') : [];
        if (inputs.length > 0) {
          inputs.forEach(input => {
            if (input.id) {
              userProgressData[input.id] = input.value;
              // 雙向綁定邏輯：保持「能不能」與「增減細節」的文字同步
              if (input.id === 'input-can-q1') {
                userProgressData['input-adjust-can-q1'] = input.value;
                const adj = document.getElementById('input-adjust-can-q1');
                if (adj) adj.value = input.value;
              } else if (input.id === 'input-adjust-can-q1') {
                userProgressData['input-can-q1'] = input.value;
                const orig = document.getElementById('input-can-q1');
                if (orig) orig.value = input.value;
              }
              if (input.id === 'input-can-q2') {
                userProgressData['input-adjust-can-q2'] = input.value;
                const adj = document.getElementById('input-adjust-can-q2');
                if (adj) adj.value = input.value;
              } else if (input.id === 'input-adjust-can-q2') {
                userProgressData['input-can-q2'] = input.value;
                const orig = document.getElementById('input-can-q2');
                if (orig) orig.value = input.value;
              }
              // 想不想路線的雙向綁定
              if (input.id === 'input-q1') {
                userProgressData['input-adjust-q1'] = input.value;
                const adj = document.getElementById('input-adjust-q1');
                if (adj) adj.value = input.value;
              } else if (input.id === 'input-adjust-q1') {
                userProgressData['input-q1'] = input.value;
                const orig = document.getElementById('input-q1');
                if (orig) orig.value = input.value;
              }
              if (input.id === 'input-q2') {
                userProgressData['input-adjust-q2'] = input.value;
                const adj = document.getElementById('input-adjust-q2');
                if (adj) adj.value = input.value;
              } else if (input.id === 'input-adjust-q2') {
                userProgressData['input-q2'] = input.value;
                const orig = document.getElementById('input-q2');
                if (orig) orig.value = input.value;
              }
              if (input.id === 'input-q3') {
                userProgressData['input-adjust-q3'] = input.value;
                const adj = document.getElementById('input-adjust-q3');
                if (adj) adj.value = input.value;
              } else if (input.id === 'input-adjust-q3') {
                userProgressData['input-q3'] = input.value;
                const orig = document.getElementById('input-q3');
                if (orig) orig.value = input.value;
              }
            }
          });
          localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
        }

        localStorage.setItem('careerRPG_page', pageId);
        document.querySelectorAll('.page-container').forEach(page => {
          page.classList.remove('active', 'exit-animation');
        });

        const target = document.getElementById(pageId);
        if (target) {
          if (pageId === 'page-event-summary') {
            const displayAble1 = document.getElementById('display-event-1');
            const q1 = userProgressData['input-can-q1'] || '無輸入內容';
            const q2 = userProgressData['input-can-q2'] || '無輸入內容';
            if (displayAble1) {
              const blockStyle = "background: rgba(255, 255, 255, 0.65); padding: 16px 24px; border-radius: 16px; margin-bottom: 16px; text-align: left; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04); border: 1px solid rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); display: flex; align-items: flex-start; gap: 12px; font-size: 1.25rem; font-style: normal; color: #3D405B; text-shadow: none;";
              const labelStyle = "font-weight: 600; color: #E07A5F; min-width: 36px; font-size: 1.3rem;";
              const textStyle = "flex: 1; line-height: 1.5; font-weight: 500;";
