            const tagsStyle = "display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; padding-left: 48px;";

            const renderTags = (tags) => {
              if (!tags || tags.length === 0) return `<span style="color:#888; font-size:0.9rem;">(無相符標籤)</span>`;
              return tags.map(t => `<div class="tag" style="background:var(--primary); color:white; padding:6px 16px; border-radius:20px; font-size:1rem; box-shadow: 0 4px 12px rgba(129, 178, 154, 0.3);">${t}</div>`).join('');
            };

            const isErrorTag = (tags) => tags && tags.length === 1 && (tags[0].includes('失敗') || tags[0].includes('無法解析') || tags[0].includes('model') || tags[0].includes('decommissioned'));

            const savedTagsQ1 = userProgressData['tags-want-q1'];
            const savedTagsQ2 = userProgressData['tags-want-q2'];
            const savedTagsQ3 = userProgressData['tags-want-q3'];

            if (semanticContent) {
              semanticContent.innerHTML = `
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q1</div>
                    <div style="${textStyle}">${q1}</div>
                  </div>
                  <div id="tags-want-q1" style="${tagsStyle}">
                    ${(savedTagsQ1 && !isErrorTag(savedTagsQ1)) ? renderTags(savedTagsQ1) : '<div class="tag" style="font-size: 1rem; padding: 6px 16px; color: #E07A5F; border: 1px solid #E07A5F; background: transparent;">⏳ 分析中...</div>'}
                  </div>
                </div>
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q2</div>
                    <div style="${textStyle}">${q2}</div>
                  </div>
                  <div id="tags-want-q2" style="${tagsStyle}">
                    ${(savedTagsQ2 && !isErrorTag(savedTagsQ2)) ? renderTags(savedTagsQ2) : '<div class="tag" style="font-size: 1rem; padding: 6px 16px; color: #E07A5F; border: 1px solid #E07A5F; background: transparent;">⏳ 分析中...</div>'}
                  </div>
                </div>
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q3</div>
                    <div style="${textStyle}">${q3}</div>
                  </div>
                  <div id="tags-want-q3" style="${tagsStyle}">
                    ${(savedTagsQ3 && !isErrorTag(savedTagsQ3)) ? renderTags(savedTagsQ3) : '<div class="tag" style="font-size: 1rem; padding: 6px 16px; color: #E07A5F; border: 1px solid #E07A5F; background: transparent;">⏳ 分析中...</div>'}
                  </div>
                </div>
              `;

              // Trigger analysis if changed, missing, or previously errored
              if (changedQ1 || !savedTagsQ1 || isErrorTag(savedTagsQ1)) {
                if (q1 !== '無輸入內容') {
                  analyzeByCloud(q1).then(tags => {
                    userProgressData['tags-want-q1'] = tags;
                    userProgressData['last-text-want-q1'] = q1.trim();
                    localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
                    const el = document.getElementById('tags-want-q1'); if (el) el.innerHTML = renderTags(tags);
                  });
                }
              }
              if (changedQ2 || !savedTagsQ2 || isErrorTag(savedTagsQ2)) {
                if (q2 !== '無輸入內容') {
                  analyzeByCloud(q2).then(tags => {
                    userProgressData['tags-want-q2'] = tags;
                    userProgressData['last-text-want-q2'] = q2.trim();
                    localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
                    const el = document.getElementById('tags-want-q2'); if (el) el.innerHTML = renderTags(tags);
                  });
                }
              }
              if (changedQ3 || !savedTagsQ3 || isErrorTag(savedTagsQ3)) {
                if (q3 !== '無輸入內容') {
                  analyzeByCloud(q3).then(tags => {
                    userProgressData['tags-want-q3'] = tags;
                    userProgressData['last-text-want-q3'] = q3.trim();
                    localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
                    const el = document.getElementById('tags-want-q3'); if (el) el.innerHTML = renderTags(tags);
                  });
                }
              }
            }
          }

          if (pageId === 'page-semantic-analysis-able') {
            localStorage.setItem('careerRPG_hasAbleHistory', 'true');
            const semanticContent = document.getElementById('semantic-content-able');
            const q1 = userProgressData['input-adjust-can-q1'] || userProgressData['input-can-q1'] || '無輸入內容';
            const q2 = userProgressData['input-adjust-can-q2'] || userProgressData['input-can-q2'] || '無輸入內容';

            const lastTextQ1 = userProgressData['last-text-able-q1'] || '';
            const changedQ1 = q1.trim() !== lastTextQ1.trim() && q1 !== '無輸入內容';
            if (changedQ1) userProgressData['tags-able-q1'] = null;

            const lastTextQ2 = userProgressData['last-text-able-q2'] || '';
            const changedQ2 = q2.trim() !== lastTextQ2.trim() && q2 !== '無輸入內容';
            if (changedQ2) userProgressData['tags-able-q2'] = null;

            const blockStyle = "background: rgba(255, 255, 255, 0.65); padding: 16px 24px; border-radius: 16px; text-align: left; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04); border: 1px solid rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); display: flex; align-items: flex-start; gap: 12px; font-size: 1.25rem; font-style: normal; color: #3D405B; text-shadow: none;";
            const labelStyle = "font-weight: 600; color: #E07A5F; min-width: 36px; font-size: 1.3rem;";
            const textStyle = "flex: 1; line-height: 1.5; font-weight: 500;";
            const tagsStyle = "display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; padding-left: 48px;";

            const renderTags = (tags) => {
              if (!tags || tags.length === 0) return `<span style="color:#888; font-size:0.9rem;">(無相符標籤)</span>`;
              return tags.map(t => `<div class="tag" style="background:var(--primary); color:white; padding:6px 16px; border-radius:20px; font-size:1rem; box-shadow: 0 4px 12px rgba(129, 178, 154, 0.3);">${t}</div>`).join('');
            };

            const isErrorTag = (tags) => tags && tags.length === 1 && (tags[0].includes('失敗') || tags[0].includes('無法解析') || tags[0].includes('model') || tags[0].includes('decommissioned'));

            const savedTagsQ1 = userProgressData['tags-able-q1'];
            const savedTagsQ2 = userProgressData['tags-able-q2'];

            if (semanticContent) {
              semanticContent.innerHTML = `
                <div class="semantic-anim-item" style="margin-bottom: 24px;">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q1</div>
                    <div style="${textStyle}">${q1}</div>
                  </div>
                  <div id="tags-able-q1" style="${tagsStyle}">
                    ${(savedTagsQ1 && !isErrorTag(savedTagsQ1)) ? renderTags(savedTagsQ1) : '<div class="tag" style="font-size: 1rem; padding: 6px 16px; color: #E07A5F; border: 1px solid #E07A5F; background: transparent;">⏳ 分析中...</div>'}
                  </div>
                </div>
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q2</div>
                    <div style="${textStyle}">${q2}</div>
                  </div>
                  <div id="tags-able-q2" style="${tagsStyle}">
                    ${(savedTagsQ2 && !isErrorTag(savedTagsQ2)) ? renderTags(savedTagsQ2) : '<div class="tag" style="font-size: 1rem; padding: 6px 16px; color: #E07A5F; border: 1px solid #E07A5F; background: transparent;">⏳ 分析中...</div>'}
                  </div>
                </div>
              `;

              if (changedQ1 || !savedTagsQ1 || isErrorTag(savedTagsQ1)) {
                if (q1 !== '無輸入內容') {
                  analyzeByCloud(q1).then(tags => {
                    userProgressData['tags-able-q1'] = tags;
                    userProgressData['last-text-able-q1'] = q1.trim();
                    localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
                    const el = document.getElementById('tags-able-q1');
                    if (el) el.innerHTML = renderTags(tags);
                  });
                }
              }
              if (changedQ2 || !savedTagsQ2 || isErrorTag(savedTagsQ2)) {
                if (q2 !== '無輸入內容') {
                  analyzeByCloud(q2).then(tags => {
                    userProgressData['tags-able-q2'] = tags;
                    userProgressData['last-text-able-q2'] = q2.trim();
                    localStorage.setItem('careerRPG_data', JSON.stringify(userProgressData));
                    const el = document.getElementById('tags-able-q2');
                    if (el) el.innerHTML = renderTags(tags);
                  });
                }
              }
            }
          }

          if (pageId === 'page-review-want' || pageId === 'page-review-able') {
            const isWant = pageId === 'page-review-want';
            const reviewContent = document.getElementById(isWant ? 'review-content-want' : 'review-content-able');

            const blockStyle = "background: rgba(255, 255, 255, 0.65); padding: 16px 24px; border-radius: 16px; text-align: left; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04); border: 1px solid rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); color: #3D405B; line-height: 1.5; font-size: 1.25rem; display: flex; align-items: flex-start; gap: 12px;";
            const labelStyle = "font-weight: 600; color: #E07A5F; min-width: 36px; font-size: 1.3rem;";
            const textStyle = "flex: 1;";

            const renderTags = (tags) => {
              if (!tags || tags.length === 0) return `<span style="color:#888; font-size:0.9rem;">(無相符標籤)</span>`;
              return tags.map(t => `<div class="tag" style="background:var(--primary); color:white; padding:6px 16px; border-radius:20px; font-size:1rem; box-shadow: 0 4px 12px rgba(129, 178, 154, 0.3); margin-top: 8px;">${t}</div>`).join('');
            };

            let htmlContent = '';

            if (isWant) {
              const q1 = userProgressData['input-adjust-q1'] || userProgressData['input-q1'] || '無輸入內容';
              const q2 = userProgressData['input-adjust-q2'] || userProgressData['input-q2'] || '無輸入內容';
              const q3 = userProgressData['input-adjust-q3'] || userProgressData['input-q3'] || '無輸入內容';

              htmlContent += `
                <div class="semantic-anim-item" style="margin-bottom: 24px;">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q1</div>
                    <div style="${textStyle}">${q1}</div>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-left: 48px;">
                    ${renderTags(userProgressData['tags-want-q1'])}
                  </div>
                </div>
                <div class="semantic-anim-item" style="margin-bottom: 24px;">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q2</div>
                    <div style="${textStyle}">${q2}</div>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-left: 48px;">
                    ${renderTags(userProgressData['tags-want-q2'])}
                  </div>
                </div>
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q3</div>
                    <div style="${textStyle}">${q3}</div>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-left: 48px;">
                    ${renderTags(userProgressData['tags-want-q3'])}
                  </div>
                </div>
              `;
            } else {
              const q1 = userProgressData['input-adjust-can-q1'] || userProgressData['input-can-q1'] || '無輸入內容';
              const q2 = userProgressData['input-adjust-can-q2'] || userProgressData['input-can-q2'] || '無輸入內容';

              htmlContent += `
                <div class="semantic-anim-item" style="margin-bottom: 24px;">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q1</div>
                    <div style="${textStyle}">${q1}</div>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-left: 48px;">
                    ${renderTags(userProgressData['tags-able-q1'])}
                  </div>
                </div>
                <div class="semantic-anim-item">
                  <div style="${blockStyle}">
                    <div style="${labelStyle}">Q2</div>
                    <div style="${textStyle}">${q2}</div>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; padding-left: 48px;">
                    ${renderTags(userProgressData['tags-able-q2'])}
                  </div>
                </div>
              `;
            }

            if (reviewContent) {
              reviewContent.innerHTML = htmlContent;
            }
          }

          target.classList.add('active');
          if (typeof updateQuickNavHighlight === 'function') {
            updateQuickNavHighlight(pageId);
          }
        }
      };

      if (currentPage && !immediate) {
        // 正常流程：播放退場動畫
        currentPage.classList.add('exit-animation');
        setTimeout(doSwitch, 600);
      } else {
        // 初始載入或強制跳轉：直接切換
        doSwitch();
      }
    }

    // 🧭 快速導覽輔助函數
    function toggleQuickNav() {
      const panel = document.getElementById('quick-nav-menu-panel');
      if (panel) panel.classList.toggle('open');
    }

    function jumpToPage(pageId) {
      goTo(pageId, true); // 使用立即跳轉模式
      toggleQuickNav();   // 自動關閉選單
    }

    function updateQuickNavHighlight(pageId) {
      document.querySelectorAll('.quick-nav-item').forEach(item => {
        if (item.getAttribute('data-page') === pageId) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
    }

    // 點擊選單外部自動關閉
    document.addEventListener('click', (e) => {
      const container = document.querySelector('.quick-nav-container');
      const panel = document.getElementById('quick-nav-menu-panel');
      if (container && panel && panel.classList.contains('open') && !container.contains(e.target)) {
        panel.classList.remove('open');
      }
    });

    // 當頁面載入時，檢查 URL 參數決定顯示哪一頁，並設定驗證與自動填入邏輯
    window.addEventListener('load', () => {
      // 啟動裝飾粒子
      createDustMotes();

      // 1. 讀取 LocalStorage 歷史紀錄
      const savedData = localStorage.getItem('careerRPG_data');
      if (savedData) {
        try {
          userProgressData = JSON.parse(savedData);
          // 2. 自動將資料填回對應的輸入框
          document.querySelectorAll('.text-input').forEach(input => {
            if (input.id && userProgressData[input.id]) {
              input.value = userProgressData[input.id];
            }
          });

          // 3. 還原現實篩選 (要不要) 的刻度狀態
          ['income', 'time', 'mobility', 'feedback'].forEach(category => {
            const val = userProgressData[`scale-${category}`];
            if (val !== undefined) {
              const nodes = document.querySelectorAll(`#scale-${category} .scale-node-wrapper`);
              if (nodes[val]) {
                nodes.forEach(el => el.classList.remove('active'));
                nodes[val].classList.add('active');
              }
            }
          });
        } catch (e) {
          console.error('讀取歷史紀錄失敗', e);
        }
      }

      // 3. 綁定防呆驗證邏輯
      setupValidation();

      // 4. 對已有資料的輸入框觸發一次驗證，讓原本已填好的按鈕解鎖
      document.querySelectorAll('.text-input').forEach(input => {
        if (input.value) {
          input.dispatchEvent(new Event('input'));
        }
      });

      const urlParams = new URLSearchParams(window.location.search);
      const step = urlParams.get('step');
      const savedPage = localStorage.getItem('careerRPG_page');

      if (step === 'page-want-or-not' && localStorage.getItem('careerRPG_hasWantHistory') === 'true') {
        goTo('page-review-want', true);
        window.history.replaceState({}, '', window.location.pathname);
      } else if (step === 'page-can-or-not' && localStorage.getItem('careerRPG_hasAbleHistory') === 'true') {
        goTo('page-review-able', true);
        window.history.replaceState({}, '', window.location.pathname);
      } else if (step) {
        goTo(step, true);
        window.history.replaceState({}, '', window.location.pathname);
      } else if (savedPage) {
        goTo(savedPage, true);
      } else {
        goTo('page-want-or-not', true);
      }
    });
  </script>

</body>

</html>